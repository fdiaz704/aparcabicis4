# Google Maps API key for the Android app.
#
# Copy this file to `secrets.properties` (which is gitignored) and replace the
# placeholder with your real key. The value is injected into AndroidManifest.xml
# at build time via `manifestPlaceholders` (see android/app/build.gradle.kts).
#
# In CI, you can instead export a MAPS_API_KEY environment variable.
MAPS_API_KEY=YOUR_KEY_HERE
