// Google Maps API key for the iOS app.
//
// Copy this file to `Secrets.xcconfig` (which is gitignored) and replace the
// placeholder with your real key. It is included from Debug.xcconfig and
// Release.xcconfig, exposed to Info.plist as `MapsApiKey` ($(MAPS_API_KEY)),
// and read at launch in AppDelegate.swift.
//
// In CI, generate this file from a secret before building.
MAPS_API_KEY = YOUR_KEY_HERE
